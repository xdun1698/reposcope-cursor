{
  "name": "reposcope",
  "version": "2.0.4",
  "description": "AI Cost Intelligence for any repo: token waste detector, security heatmap, interactive repo map, and AI game-plan tracker. Works on any language/framework — no repo-specific setup required.",
  "author": {
    "name": "NxGen Tech Solutions",
    "email": "support@reposcope.app"
  },
  "icon": "assets/reposcope-icon.png",
  "homepage": "https://reposcope.app",
  "repository": "https://github.com/xdun1698/reposcope-cursor",
  "license": "MIT",
  "keywords": [
    "token-analysis",
    "security",
    "repo-map",
    "ai-cost",
    "code-quality",
    "game-plan"
  ],
  "hooks": [
    {
      "event": "onGitCommit",
      "action": "scanCommitDiff",
      "priority": "high"
    },
    {
      "event": "onFileSave",
      "action": "analyzeTokenWaste",
      "priority": "medium"
    },
    {
      "event": "onCursorChat",
      "action": "injectSuggestions",
      "priority": "low"
    },
    {
      "event": "onCursorOpen",
      "action": "repoTrace",
      "output": "repoTab"
    },
    {
      "event": "onGitCommit",
      "action": "vulnScan",
      "output": "securityTab"
    },
    {
      "event": "onFileSave",
      "action": "tokenAudit",
      "output": "tokenTab"
    },
    {
      "event": "onCursorAgentComplete",
      "action": "updateGamePlan",
      "input": "agentOutput",
      "output": "gameplanTab",
      "priority": "low"
    }
  ],
  "subagents": [
    {
      "id": "tokenOptimizer",
      "name": "Token Saver",
      "description": "Scans context for junk — unused vars, bloated imports, stale indexes. Shows waste in sidebar graph.",
      "trigger": "onFileSave OR onCursorChat",
      "output": "sidebarTab",
      "icon": "graph-icon"
    },
    {
      "id": "securityGuard",
      "name": "Security Flagger",
      "description": "Real-time vuln highlighter: secrets, injections, deps. Red/yellow/green heatmap on code.",
      "trigger": "onGitCommit OR onCursorChat",
      "output": "overlay + sidebarTab",
      "icon": "shield-icon"
    },
    {
      "id": "repoWatcher",
      "name": "Repo Viewer",
      "description": "Live repo map — click to jump, see Cursor build history, trace token hogs.",
      "trigger": "onCursorOpen OR onGitCommit",
      "output": "sidebarTab",
      "icon": "tree-icon"
    }
  ],
  "skills": [
    {
      "name": "tokenAudit",
      "description": "Runs lightweight AST parse — flags 200+ token leaks per file.",
      "input": "filePath",
      "output": "wasteReport"
    },
    {
      "name": "vulnScan",
      "description": "Checks for OWASP top 10 + secrets. Returns severity + fix.",
      "input": "diff OR fullFile",
      "output": "vulnList"
    },
    {
      "name": "repoTrace",
      "description": "Builds git tree + Cursor session log. Links code to past runs.",
      "input": "repoRoot",
      "output": "interactiveTree"
    },
    {
      "name": "gamePlan",
      "description": "Parses agent output, extracts goals, updates plan tracker.",
      "input": "agentOutput",
      "output": "planUpdate"
    }
  ],
  "sidebar": {
    "tabs": [
      {
        "id": "tokenTab",
        "title": "Token Audit",
        "icon": "graph",
        "view": "tokenAuditView"
      },
      {
        "id": "securityTab",
        "title": "Security",
        "icon": "shield",
        "view": "securityView"
      },
      {
        "id": "repoTab",
        "title": "Repo Map",
        "icon": "tree",
        "view": "repoView"
      },
      {
        "id": "gameplanTab",
        "title": "Game Plan",
        "icon": "checklist",
        "view": "gameplanView"
      }
    ]
  },
  "permissions": {
    "network": "none",
    "filesystem": "read",
    "terminal": "none"
  }
}
